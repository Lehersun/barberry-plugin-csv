{
    "name": "barberry/plugin-csv",
    "type": "barberry-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Alexey Boychenko",
            "email": "lehersun@gmail.com"
        }
    ],
    "require": {
        "php": "^5.6 || ^7.0 || ^8.0",
        "ext-iconv": "*",
        "ext-mbstring": "*",
        "barberry/interfaces": "dev-master as 2.7.x-dev",
        "barberry/plugin-installer": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-0": {
            "Barberry\\Plugin\\Csv": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "barberry/plugin-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
